meta {
  name: Create Connection
  type: http
  seq: 54
}

post {
  url: {{cacheLoaderBaseUrl}}/connections
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
{
  "name": "Source DB",
  "host": "{{sourceDbHost}}",
  "port": "{{sourceDbPort}}",
  "database": "{{sourceDbName}}",
  "username": "{{sourceDbUser}}",
  "password": "{{sourceDbPassword}}",
  "ssl": false
}
}
